{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com///nextflow_schema.json",
  "title": "NASA GeneLab Data Processing Host Read Estimation workflow parameters",
  "description": "GeneLab workflow for estimating host reads in metagenomics sequencing data, as described in GL-DPPD-7109-A",
  "type": "object",
  "properties": {
    "dp_tools_plugin": {
      "type": "string",
          "description": "Alternative dp_tools plugin"
    },
    "osd": {
      "type": "string",
      "description": "OSD accession number (e.g. 'OSD-47')",
      "pattern": "^OSD-[0-9]+$"
    },
    "glds": {
      "type": "string",
      "description": "GLDS accession number (e.g. 'GLDS-47')",
      "pattern": "^GLDS-[0-9]+$"
    },
    "runsheet_path": {
      "type": "string",
      "description": "Path to the input runsheet",
      "format": "file-path"
    },
    "isa_archive_path": {
      "type": "string",
      "description": "Path to the ISA.zip for an OSDR dataset. '--accession' must also be used",
      "format": "file-path"
    },
    "sample_id_list": {
      "type": "string",
      "description": "list of unique sample IDs that identifies the files to process"
    },
    "reads_dir": {
      "type": "string",
      "description": "Path to input reads"
    },
    "is_single": {
      "type": "boolean",
      "default": false,
      "description": "Are the reads single-ended?"
    },
    "R1_suffix": {
      "type": "string",
      "default": "_R1_raw.fastq.gz",
      "description": "file suffix for mate1 reads"
    },
    "R2_suffix": {
      "type": "string",
      "default": "_R2_raw.fastq.gz",
      "description": "file suffix for mate2 reads"
    },
    "single_suffix": {
      "type": "string",
      "default": "_raw.fastq.gz",
      "description": "file suffix for single-ended reads"
    },
    "host": {
      "type": "string",
      "default": "mouse",
      "description": "simple name of host organism"
    },
    "hosts_table": {
      "type": "string",
      "default": "${projectDir}/assets/hosts.csv",
      "description": "comma-separated table of host information",
      "hidden": true
    },
    "ref_dbs_dir": {
      "type": "string",
      "default": "./kraken2DBs",
      "description": "path to kraken2 databases"
    },
    "ref_fasta": {
      "type": "string",
      "description": "Specifies a custom reference FASTA file to use by providing a local path or a URL"
    },
    "assembly_name": {
      "type": "string",
      "description": "Specifies the assembly name for the host reference genome"
    },
    "assembly_acc": {
      "type": "string",
      "description": "Specifies the assembly accession number for the host reference genome"
    },
    "db_url": {
      "type": "string",
      "description": "Specifies a URL to download a pre-built Kraken2 database from"
    },
    "assay_table": {
      "type": "string",
      "description": "Path to assay table instead of extracting it from an ISA zip file when updating the assay table",
      "format": "file-path"
    },
    "publish_dir_mode": {
      "type": "string",
      "default": "link",
      "description": "Nextflow workflow publish mode",
      "enum": ["copy", "copyNoFollow", "link", "move", "relink", "symlink"],
      "hidden": true
    },
    "trace_timestamp": {
      "type": "string",
      "hidden": true
    }
  },
  "required": ["ref_dbs_dir"]
}
